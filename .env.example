# ============================================
# TRADING AGENT — Variables d'environnement
# ============================================
# Copie ce fichier en .env et remplis tes vraies clés
# NE JAMAIS partager le fichier .env !
# ============================================

# --- Claude API (Phase 2+) ---
# Créer une clé sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Telegram Bot (Phase 2+) ---
# Créer un bot via @BotFather sur Telegram
# Pour trouver ton CHAT_ID : envoie un message à ton bot,
# puis va sur https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TOKEN=8XXXX
TELEGRAM_CHAT_ID=XXXXX

# --- Reddit API (Phase 3) ---
# Créer une app sur : https://www.reddit.com/prefs/apps/
REDDIT_CLIENT_ID=ton_client_id
REDDIT_CLIENT_SECRET=ton_client_secret

# --- Configuration Trading ---
# Capital en dollars
CAPITAL=10000
# Risque par trade en pourcentage
RISK_PCT=1.0
